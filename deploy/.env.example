# Copy to .env next to compose.yaml and adjust.
# Must be the host:port clients use for WebSocket (same value as signaling's public node id).
# Use the VM's LAN IP or DNS name, not "signaling" (that name only works inside the compose network).

PUBLIC_HOST=127.0.0.1

# Must match between connector and signaling.
CONNECTOR_TOKEN_SECRET=change-me-in-production

# SFU container on the Compose network (service name `sfu`, gRPC 50051).
SUPERVISOR_SFU_INSTANCES=sfu-1|http://sfu:50051|200
